# Claude container env file — copy to .env.claude and fill in. NEVER commit .env.claude.
# CUSTOMIZE: a fine-grained GitHub PAT with repo read/write for this project
GIT_TOKEN=
GIT_USERNAME=x-access-token
# Leave ANTHROPIC_API_KEY empty when using Claude Code web login (OAuth). Set if using API key flow.
ANTHROPIC_API_KEY=
# Optionally set a branch to auto-create/switch on start:
# NEW_BRANCH=agent_claude_vm/feature_123_foo_bar_baz
# Which Ralph loop this clone runs (0..3). Unset ⇒ 0. One clone per loop id.
RALPH_LOOP_ID=0
